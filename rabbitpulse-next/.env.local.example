# ---------------------------------------------------------------------------
# RabbitPulse — local environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values for local dev.
# `.env.local` is gitignored — never commit secrets.
#
# In production, set the same variables in the Vercel dashboard under
# Project Settings → Environment Variables.
#
# Variables prefixed `NEXT_PUBLIC_` are exposed to the browser.
# Anything else stays server-side only.
# ---------------------------------------------------------------------------

# ---- Phase 4 (media / CDN) ------------------------------------------------
# Streaming URL for the hero video. Optional in dev (falls back to the
# local /images/sefer-video.mp4 if unset).
#
# In production the MP4 should NOT be served from /public — it ships
# as a single 22 MB blob with no streaming. Recommended hosts:
#
#   - Vercel Blob:   https://<store>.public.blob.vercel-storage.com/sefer-video.mp4
#   - Cloudinary:    https://res.cloudinary.com/<cloud>/video/upload/q_auto/sefer-video.mp4
#   - Mux (HLS):     https://stream.mux.com/<playback-id>.m3u8   (needs HLS player)
#
# Whichever you pick, set the same variable in the Vercel dashboard
# (Project Settings → Environment Variables) so production reads
# from the CDN.
# NEXT_PUBLIC_SEFER_VIDEO_URL=

# ---- Phase 6+ (Solana wallet) ---------------------------------------------
# Network: "devnet" while testing, "mainnet-beta" for production.
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC endpoint. The default public RPC is rate-limited; use Helius or
# QuickNode for anything beyond local clicking around.
# Example (Helius):
#   https://devnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
